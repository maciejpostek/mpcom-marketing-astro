{
  "siteUrl": "https://www.maciejpostek.com",
  "name": "mpcom-marketing-astro",
  "format": "astro",
  "editor": {
    "theme": "light"
  },
  "i18n": {
    "defaultLocale": "en",
    "locales": [
      {
        "code": "en",
        "name": "English",
        "nativeName": "English",
        "langTag": "en-US"
      }
    ]
  },
  "breakpoints": {
    "tablet": {
      "breakpoint": 1024,
      "previewPoint": 880
    },
    "mobile": {
      "breakpoint": 540,
      "previewPoint": 400
    }
  },
  "responsiveScales": {
    "enabled": false,
    "baseReference": 16
  },
  "fonts": [],
  "imageFormat": "webp",
  "baseComponent": "SiteShell",
  "prefetch": {
    "enabled": false
  },
  "deploy": {
    "method": "cloudflare"
  }
}
