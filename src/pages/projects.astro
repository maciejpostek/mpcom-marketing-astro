---
import { ExternalLink } from "@lucide/astro";
import { BaseLayout } from "meno-astro/components";
import PageHeader from "../components/PageHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SiteShell from "../components/SiteShell.astro";
import { projects } from "../data/content";

const caseStudies = projects.filter((project) => project.type === "case-study");
const archive = projects.filter((project) => project.type === "project");
const meta = {
  title: "Projects — MPCOM",
  description:
    "Selected interface systems, product projects and the path toward design engineering."
};
---

<BaseLayout meta={meta}>
  <SiteShell>
  <div class="page">
    <PageHeader
      eyebrow="Projects"
      title="System work, product interfaces and the path that led here."
      description="Featured cases explain the thinking. The archive shows the broader body of delivered work."
    />

    <section class="featured-grid projects-featured">
      {caseStudies.map((project) => <ProjectCard project={project} />)}
    </section>

    <section class="project-archive">
      <div class="proof-section__header">
        <span class="metric-label">Project archive</span><span>{archive.length} selected projects</span>
      </div>
      {
        archive.map((project) => (
          <article class="archive-row">
            <span class="archive-row__year">{project.date}</span>
            <div><h3>{project.title}</h3><p>{project.summary}</p></div>
            <span>{project.scope}</span>
            <span class="badge">{project.industry}</span>
            <a class="icon-button" href={project.liveUrl ?? "#"} title={`Open ${project.title}`}>
              <ExternalLink size={16} />
            </a>
          </article>
        ))
      }
    </section>
  </div>
  </SiteShell>
</BaseLayout>
