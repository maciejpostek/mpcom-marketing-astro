---
import { ArrowRight, Braces, PanelsTopLeft, Sparkles } from "@lucide/astro";
import { BaseLayout } from "meno-astro/components";
import Callout from "../components/Callout.astro";
import Portrait from "../components/Portrait.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteShell from "../components/SiteShell.astro";
import { projects, stages } from "../data/content";

const featuredProjects = projects.filter((project) => project.type === "case-study").slice(0, 2);
const meta = {
  title: "MPCOM — Product systems, designed to evolve",
  description:
    "Interface systems connecting product design, front-end components, AI context and governance."
};
---

<BaseLayout meta={meta}>
  <SiteShell>
  <div class="page">
    <section class="page-intro about-intro">
      <div class="about-hero-layout">
        <div class="about-hero-copy">
          <div class="eyebrow">
            <span class="eyebrow__line"></span>
            Product systems · design + development
          </div>
          <h1>
            Interfaces designed as systems,
            <span class="text-secondary">ready to evolve with people and AI.</span>
          </h1>
          <p class="lead">
            I help product teams turn fragmented UI into a designed, coded and documented
            interface ecosystem.
          </p>
          <div class="intro-actions">
            <a class="button button--primary" href="/process">
              Explore the process
              <ArrowRight size={15} />
            </a>
            <a class="button button--secondary" href="/contact">Discuss a project</a>
          </div>
        </div>
        <div class="about-portrait">
          <Portrait variant="hero" title="Maciej Postek" />
          <div class="about-portrait__caption">
            <span>Maciej Postek</span>
            <strong>Product designer & design systems builder</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="overview-strip">
      <div><span>Core focus</span><strong>Product UI & design systems</strong></div>
      <div><span>Working layer</span><strong>Figma → code → context</strong></div>
      <div><span>Best fit</span><strong>B2B SaaS & dashboards</strong></div>
      <div><span>Location</span><strong>Warsaw · EU / US</strong></div>
    </section>

    <section class="section section--bordered">
      <SectionHeading
        index="01"
        eyebrow="The approach"
        title="A product should not become harder to change every time it grows."
        description="The work connects three layers that are too often separated."
      />
      <div class="three-column-framework">
        <article class="framework-column">
          <div class="framework-column__top"><span><PanelsTopLeft size={18} /></span><small>01</small></div>
          <h3>Interface System Design</h3>
          <p>Product flows, information architecture, reusable UI and a Figma design system.</p>
          <ul><li>UX & product flows</li><li>Foundations</li><li>Components & states</li></ul>
        </article>
        <article class="framework-column">
          <div class="framework-column__top"><span><Sparkles size={18} /></span><small>02</small></div>
          <h3>AI Context & Governance</h3>
          <p>Patterns, rules and documentation that keep design, code and AI aligned.</p>
          <ul><li>Markdown specs</li><li>Reusable patterns</li><li>Change processes</li></ul>
        </article>
        <article class="framework-column">
          <div class="framework-column__top"><span><Braces size={18} /></span><small>03</small></div>
          <h3>Front-end Design System</h3>
          <p>Reusable components, technical rules and a source of truth in code.</p>
          <ul><li>React components</li><li>Design tokens</li><li>Storybook</li></ul>
        </article>
      </div>
    </section>

    <section class="section section--bordered">
      <SectionHeading
        index="02"
        eyebrow="Current proof"
        title="The portfolio is becoming the product."
        description="The public system documents the process today and creates a foundation for the future client workspace."
      />
      <div class="featured-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="section section--bordered compact-process-preview">
      <SectionHeading
        index="03"
        eyebrow="Reference process"
        title="A clear path from uncertainty to an operating system."
        description="Every engagement is assembled from the same reference process, then adapted to the product."
      />
      <div class="mini-process">
        {
          stages.slice(0, 5).map((stage) => (
            <button
              class:list={["mini-process__stage", { "mini-process__stage--active": stage.id === "discovery" }]}
              type="button"
              data-open-stage={stage.id}
            >
              <span>{stage.number}</span>
              <strong>{stage.name}</strong>
              <ArrowRight size={14} />
            </button>
          ))
        }
      </div>
      <div class="section-footer-action">
        <a class="text-link" href="/process">
          Open the complete process
          <ArrowRight size={15} />
        </a>
      </div>
    </section>

    <Callout
      eyebrow="Start with context"
      title="Before estimating the full system, define what actually needs to be built."
      action="Start with Discovery"
      href="/contact"
      portrait
    />
  </div>
  </SiteShell>
</BaseLayout>
