---
import { resolveProps, style } from "meno-astro";

const __props = resolveProps(Astro, {
  label: { type: "string", default: "Field label" },
  name: { type: "string", default: "field" },
  placeholder: { type: "string", default: "Type here" },
  type: { type: "select", default: "text", options: ["text", "email", "url"] },
  multiline: { type: "boolean", default: false }
});
const { label, name, placeholder, type, multiline, class: className } = __props;

const __meno = { acceptsStyles: true };
---

<label
  class={style(
    { base: { display: "grid", gap: "8px", color: "var(--gray-700)", fontSize: "12px", fontWeight: "500" }, tablet: {}, mobile: {} },
    __props,
    { root: true, label: "Form field" }
  )}
>
  <span>{label}</span>
  {multiline ? (
    <textarea
      name={name}
      placeholder={placeholder}
      class={style(
        {
          base: {
            minHeight: "142px",
            padding: "13px 14px",
            resize: "vertical",
            border: "1px solid var(--gray-300)",
            borderRadius: "4px",
            backgroundColor: "#ffffff",
            color: "var(--gray-900)",
            font: "inherit"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    ></textarea>
  ) : (
    <input
      name={name}
      type={type}
      placeholder={placeholder}
      class={style(
        {
          base: {
            minHeight: "44px",
            padding: "0 14px",
            border: "1px solid var(--gray-300)",
            borderRadius: "4px",
            backgroundColor: "#ffffff",
            color: "var(--gray-900)",
            font: "inherit"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    />
  )}
</label>
