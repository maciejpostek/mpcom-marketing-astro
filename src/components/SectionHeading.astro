---
import { resolveProps } from "meno-astro";

const __props = resolveProps(Astro, {
  index: { type: "string", default: "01" },
  eyebrow: { type: "string", default: "Section" },
  title: { type: "string", default: "Section title" },
  description: { type: "string", default: "Supporting description." }
});
const { index, eyebrow, title, description } = __props;

const __meno = { acceptsStyles: true };
---

<div class="section-heading">
  <span class="section-heading__index">{index}</span>
  <div>
    <span class="metric-label">{eyebrow}</span>
    <h2>{title}</h2>
  </div>
  <p>{description}</p>
</div>
