---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  description: string;
}

const { index, eyebrow, title, description } = Astro.props;
---

<div class="section-heading">
  <span class="section-heading__index">{index}</span>
  <div>
    <span class="metric-label">{eyebrow}</span>
    <h2>{title}</h2>
  </div>
  <p>{description}</p>
</div>
