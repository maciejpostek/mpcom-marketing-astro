---
import { resolveProps, style } from "meno-astro";
import { Link } from "meno-astro/components";
import ActionButton from "./ActionButton.astro";
import NavItem from "./NavItem.astro";

const __props = resolveProps(Astro, {
  aboutActive: { type: "boolean", default: false },
  processActive: { type: "boolean", default: false },
  servicesActive: { type: "boolean", default: false },
  clientsActive: { type: "boolean", default: false },
  projectsActive: { type: "boolean", default: false },
  contactActive: { type: "boolean", default: false }
});
const {
  aboutActive,
  processActive,
  servicesActive,
  clientsActive,
  projectsActive,
  contactActive,
  class: className,
} = __props;
---

<div
  class={style(
    {
      base: {
        minHeight: "100vh",
        display: "grid",
        gridTemplateColumns: "236px minmax(0, 1fr)",
        backgroundColor: "var(--white)",
        color: "var(--gray-900)",
        fontFamily: "\"Inter\", Arial, sans-serif"
      },
      tablet: { gridTemplateColumns: "196px minmax(0, 1fr)" },
      mobile: { display: "block" }
    },
    __props,
    { root: true, label: "MPCOM application shell" }
  )}
>
  <aside
    class={style(
      {
        base: {
          minHeight: "100vh",
          display: "flex",
          flexDirection: "column",
          borderRight: "1px solid var(--gray-200)",
          backgroundColor: "var(--white)"
        },
        tablet: {},
        mobile: { display: "none" }
      },
      __props,
      { label: "Sidebar" }
    )}
  >
    <Link
      href="/"
      class={style(
        {
          base: {
            minHeight: "64px",
            padding: "0 24px",
            display: "flex",
            alignItems: "center",
            gap: "12px",
            borderBottom: "1px solid var(--gray-200)",
            color: "var(--gray-950)",
            fontSize: "13px",
            fontWeight: "600",
            textDecoration: "none"
          },
          tablet: { padding: "0 18px" },
          mobile: {}
        },
        __props
      )}
      aria-label="MPCOM home"
    >
      <span
        class={style(
          {
            base: {
              width: "28px",
              height: "18px",
              display: "flex",
              alignItems: "flex-end",
              gap: "2px"
            },
            tablet: {},
            mobile: {}
          },
          __props
        )}
      >
        <i class={style({ base: { width: "8px", height: "4px", display: "block", backgroundColor: "var(--gray-950)" }, tablet: {}, mobile: {} }, __props)} />
        <i class={style({ base: { width: "8px", height: "8px", display: "block", backgroundColor: "var(--gray-950)" }, tablet: {}, mobile: {} }, __props)} />
        <i class={style({ base: { width: "8px", height: "12px", display: "block", backgroundColor: "var(--gray-950)" }, tablet: {}, mobile: {} }, __props)} />
      </span>
      <span>MPCOM</span>
    </Link>

    <nav
      class={style(
        {
          base: {
            padding: "30px 16px",
            display: "flex",
            flexDirection: "column",
            gap: "2px"
          },
          tablet: { padding: "26px 12px" },
          mobile: {}
        },
        __props,
        { label: "Public navigation" }
      )}
      aria-label="Public navigation"
    >
      <span
        class={style(
          {
            base: {
              margin: "0 10px 10px",
              color: "var(--gray-500)",
              fontSize: "10px",
              fontWeight: "600",
              textTransform: "uppercase"
            },
            tablet: {},
            mobile: {}
          },
          __props
        )}
      >
        Explore
      </span>
      <NavItem text="About" link={{ href: "/" }} active={aboutActive} />
      <NavItem text="Process" link={{ href: "/process" }} active={processActive} />
      <NavItem text="Services" link={{ href: "/services" }} active={servicesActive} />
      <NavItem text="Clients" link={{ href: "/clients" }} active={clientsActive} />
      <NavItem text="Projects" link={{ href: "/projects" }} active={projectsActive} />
      <NavItem text="Contact" link={{ href: "/contact" }} active={contactActive} />
    </nav>

    <Link
      href="/contact"
      class={style(
        {
          base: {
            marginTop: "auto",
            padding: "18px 16px",
            display: "grid",
            gridTemplateColumns: "38px minmax(0, 1fr) 18px",
            gap: "10px",
            alignItems: "center",
            borderTop: "1px solid var(--gray-200)",
            color: "var(--gray-900)",
            textDecoration: "none"
          },
          tablet: { gridTemplateColumns: "34px minmax(0, 1fr)" },
          mobile: {}
        },
        __props,
        {
          interactive: [
            {
              name: "hover",
              prefix: "",
              postfix: ":hover",
              style: { base: { backgroundColor: "var(--gray-50)" } }
            }
          ]
        }
      )}
    >
      <img
        class={style(
          {
            base: {
              width: "38px",
              height: "38px",
              display: "block",
              borderRadius: "50%",
              objectFit: "cover"
            },
            tablet: { width: "34px", height: "34px" },
            mobile: {}
          },
          __props
        )}
        src="/images/maciej-portrait.jpg"
        alt="Maciej Postek"
      />
      <span>
        <strong
          class={style(
            {
              base: {
                display: "block",
                fontSize: "11px",
                fontWeight: "500"
              },
              tablet: {},
              mobile: {}
            },
            __props
          )}
        >
          Maciej Postek
        </strong>
        <small
          class={style(
            {
              base: {
                marginTop: "4px",
                display: "block",
                color: "var(--gray-500)",
                fontSize: "9px"
              },
              tablet: {},
              mobile: {}
            },
            __props
          )}
        >
          Design Engineer
        </small>
      </span>
      <span
        class={style(
          {
            base: { color: "var(--gray-400)", fontSize: "13px" },
            tablet: { display: "none" },
            mobile: {}
          },
          __props
        )}
      >
        {"->"}
      </span>
    </Link>
  </aside>

  <div class={style({ base: { minWidth: "0" }, tablet: {}, mobile: {} }, __props)}>
    <header
      class={style(
        {
          base: {
            minHeight: "64px",
            padding: "0 28px",
            display: "flex",
            alignItems: "center",
            justifyContent: "space-between",
            gap: "24px",
            borderBottom: "1px solid var(--gray-200)",
            backgroundColor: "var(--white)"
          },
          tablet: { padding: "0 22px" },
          mobile: { minHeight: "58px", padding: "0 18px" }
        },
        __props,
        { label: "Top bar" }
      )}
    >
      <div
        class={style(
          {
            base: {
              display: "flex",
              alignItems: "center",
              gap: "18px",
              color: "var(--gray-600)",
              fontSize: "11px"
            },
            tablet: {},
            mobile: {}
          },
          __props
        )}
      >
        <span
          class={style(
            {
              base: { display: "inline-flex", alignItems: "center", gap: "8px" },
              tablet: {},
              mobile: {}
            },
            __props
          )}
        >
          <i
            class={style(
              {
                base: {
                  width: "7px",
                  height: "7px",
                  display: "block",
                  borderRadius: "50%",
                  backgroundColor: "var(--green-600)"
                },
                tablet: {},
                mobile: {}
              },
              __props
            )}
          />
          Available for Q4
        </span>
        <span class={style({ base: { color: "var(--gray-400)" }, tablet: {}, mobile: { display: "none" } }, __props)}>
          Warsaw · GMT+2
        </span>
      </div>
      <div
        class={style(
          {
            base: { display: "flex", alignItems: "center", gap: "14px" },
            tablet: {},
            mobile: {}
          },
          __props
        )}
      >
        <span
          class={style(
            {
              base: { color: "var(--gray-500)", fontSize: "10px" },
              tablet: { display: "none" },
              mobile: {}
            },
            __props
          )}
        >
          Always open to talk
        </span>
        <ActionButton text="Contact" link={{ href: "/contact" }} variant="primary" />
      </div>
    </header>
    <main
      class={style(
        {
          base: {
            width: "100%",
            maxWidth: "var(--page-max)",
            margin: "0 auto",
            padding: "0 var(--page-inset)"
          },
          tablet: { padding: "0 32px" },
          mobile: { padding: "0 18px" }
        },
        __props,
        { label: "Main content" }
      )}
    >
      <slot />
    </main>
  </div>
</div>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--white);
  }

  button,
  input,
  textarea {
    font: inherit;
  }
</style>
