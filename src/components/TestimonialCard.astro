---
import { resolveProps, style } from "meno-astro";

const __props = resolveProps(Astro, {
  quote: { type: "string", default: "Selected client feedback." },
  client: { type: "string", default: "Client" },
  person: { type: "string", default: "Product lead" },
  role: { type: "string", default: "B2B SaaS" }
});
const { quote, client, person, role, class: className } = __props;

const __meno = { acceptsStyles: true };
---

<article
  class={style(
    {
      base: {
        minHeight: "270px",
        padding: "28px",
        display: "flex",
        flexDirection: "column",
        justifyContent: "space-between",
        backgroundColor: "var(--gray-50)",
        border: "1px solid var(--gray-200)"
      },
      tablet: {},
      mobile: {}
    },
    __props,
    { root: true, label: "Testimonial" }
  )}
>
  <p
    class={style(
      { base: { margin: "0", color: "var(--gray-900)", fontSize: "18px", lineHeight: "1.55" }, tablet: {}, mobile: {} },
      __props
    )}
  >
    “{quote}”
  </p>
  <div class={style({ base: { paddingTop: "26px", borderTop: "1px solid var(--gray-200)" }, tablet: {}, mobile: {} }, __props)}>
    <strong class={style({ base: { display: "block", fontSize: "14px", fontWeight: "600" }, tablet: {}, mobile: {} }, __props)}>
      {client}
    </strong>
    <span class={style({ base: { display: "block", marginTop: "5px", color: "var(--gray-500)", fontSize: "12px" }, tablet: {}, mobile: {} }, __props)}>
      {person} · {role}
    </span>
  </div>
</article>
