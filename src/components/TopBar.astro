---
import { CalendarDays, Moon, Sun } from "@lucide/astro";
---

<header class="topbar">
  <div class="topbar__cluster">
    <span class="utility-item">
      <span class="availability-dot"></span>
      Available for Q4
    </span>
    <span class="utility-divider"></span>
    <span class="utility-item">
      Warsaw <span data-warsaw-time>--:--:--</span> · <span data-warsaw-zone>Europe/Warsaw</span>
    </span>
    <span class="utility-item utility-item--muted">Your time <span data-local-time>--:--</span></span>
  </div>
  <div class="topbar__actions">
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color mode">
      <Moon class="theme-icon theme-icon--moon" size={15} />
      <Sun class="theme-icon theme-icon--sun" size={15} />
    </button>
    <span class="topbar__note">Always open to talk</span>
    <a class="button button--primary" href="/contact">
      <CalendarDays size={15} />
      Contact
    </a>
  </div>
</header>
