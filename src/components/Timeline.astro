---
import { CalendarDays, ChevronRight } from "@lucide/astro";
import type { Stage } from "../data/content";

interface Props {
  stages: Stage[];
}

const { stages } = Astro.props;
const totalWeeks = 8;
---

<section class="timeline-shell">
  <div class="timeline-shell__header">
    <div>
      <span class="metric-label">Reference project timeline</span>
      <strong>Ideal system build</strong>
    </div>
    <div class="timeline-legend">
      <span><i class="legend-dot legend-dot--active"></i> Start here</span>
      <span><i class="legend-dot"></i> Next stages</span>
    </div>
  </div>
  <div class="timeline-scroll">
    <div class="timeline-canvas">
      <div class="timeline-grid-lines">
        {Array.from({ length: totalWeeks }).map(() => <div></div>)}
      </div>
      <div class="timeline-rows">
        {
          stages.map((stage) => {
            const left = ((stage.startWeek - 1) / totalWeeks) * 100;
            const width = (stage.durationWeeks / totalWeeks) * 100;
            const isDiscovery = stage.id === "discovery";
            return (
              <div class:list={["timeline-row", { "has-start-cta": isDiscovery }]}>
                <button
                  class:list={[
                    "timeline-stage",
                    isDiscovery ? "timeline-stage--active" : "timeline-stage--planned"
                  ]}
                  style={`left:${left}%;width:${width}%`}
                  type="button"
                  data-open-stage={stage.id}
                >
                  <span class="timeline-stage__number">{stage.number}</span>
                  <strong>{stage.name}</strong>
                  <ChevronRight size={15} />
                </button>
                {isDiscovery && (
                  <a class="timeline-start-cta" style={`left:${left}%`} href="/contact">
                    <CalendarDays size={12} />
                    Book intro call
                  </a>
                )}
              </div>
            );
          })
        }
      </div>
      <div class="timeline-weeks">
        {
          Array.from({ length: totalWeeks }).map((_, index) => (
            <div>
              <span>Week {index + 1}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <div class="timeline-help">
    <span>Scroll horizontally to explore the complete project</span>
    <span>Select any stage to open its context</span>
  </div>
</section>
