---
import { Check, Link2, X } from "@lucide/astro";
import type { PortfolioProject } from "../data/content";

interface Props {
  projects: PortfolioProject[];
}

const { projects } = Astro.props;
const caseStudies = projects.filter((project) => project.type === "case-study");
---

<div class="drawer-layer" data-case-drawer hidden>
  <button class="drawer-backdrop" type="button" data-close-case aria-label="Close panel"></button>
  <aside class="drawer drawer--case" role="dialog" aria-modal="true" aria-label="Case study details">
    <div class="drawer__topbar">
      <span class="badge badge--blue" data-component-size="tiny">Case Study</span>
      <button class="icon-button" data-component-size="small" type="button" data-close-case title="Close panel">
        <X size={17} />
      </button>
    </div>
    <div class="drawer__content" data-case-content></div>
    <div class="drawer__footer drawer__footer--case">
      <span>Shareable project context</span>
      <button type="button" data-component-size="small" data-copy-case-link>
        <Link2 size={15} />
        Copy link
      </button>
    </div>
  </aside>
</div>

{
  caseStudies.map((project) => (
    <template data-case-template={project.slug}>
      <div class="case-drawer-image">
        <img src={project.image} alt={project.imageAlt} />
      </div>
      <div class="drawer__title">
        <span>{project.industry}</span>
        <h2>{project.title}</h2>
        <p>{project.summary}</p>
      </div>
      <div class="drawer__meta">
        <div>
          <span>Date</span>
          <strong>{project.date}</strong>
        </div>
        <div>
          <span>Scope</span>
          <strong>{project.scope}</strong>
        </div>
      </div>
      <section class="drawer-section">
        <h3>Problem</h3>
        <p class="drawer-copy">{project.problem}</p>
      </section>
      <section class="drawer-section">
        <h3>Solution</h3>
        <p class="drawer-copy">{project.solution}</p>
      </section>
      <section class="drawer-section">
        <h3>System architecture</h3>
        <div class="architecture-list">
          {project.architecture.map((layer, index) => (
            <div>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{layer}</strong>
            </div>
          ))}
        </div>
      </section>
      <section class="drawer-section">
        <h3>Outputs</h3>
        <ul class="check-list">
          {project.outputs.map((output) => (
            <li>
              <Check size={14} />
              {output}
            </li>
          ))}
        </ul>
      </section>
      <section class="drawer-section">
        <h3>Stack</h3>
        <div class="tag-list tag-list--compact">
          {project.stack.map((item) => <span>{item}</span>)}
        </div>
      </section>
    </template>
  ))
}
