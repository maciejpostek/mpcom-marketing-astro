---
import { ArrowRight } from "@lucide/astro";
import { resolveProps } from "meno-astro";
import Portrait from "./Portrait.astro";

const __props = resolveProps(Astro, {
  eyebrow: { type: "string", default: "Start with context" },
  title: { type: "string", default: "Define what the system actually needs." },
  action: { type: "string", default: "Start a conversation" },
  href: { type: "link", default: { href: "/contact" } },
  portrait: { type: "boolean", default: false }
});
const { eyebrow, title, action, href, portrait } = __props;

const __meno = { acceptsStyles: true };
---

<section class="callout">
  <div class="callout__content">
    {portrait && <Portrait variant="callout" title="Maciej Postek" />}
    <div>
      <span class="metric-label">{eyebrow}</span>
      <h2>{title}</h2>
    </div>
  </div>
  <a class="button button--primary" href={typeof href === "string" ? href : href.href}>
    {action}
    <ArrowRight size={15} />
  </a>
</section>
