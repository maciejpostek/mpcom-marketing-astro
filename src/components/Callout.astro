---
import { ArrowRight } from "@lucide/astro";
import Portrait from "./Portrait.astro";

interface Props {
  eyebrow: string;
  title: string;
  action: string;
  href: string;
  portrait?: boolean;
}

const { eyebrow, title, action, href, portrait = false } = Astro.props;
---

<section class="callout">
  <div class="callout__content">
    {portrait && <Portrait variant="callout" title="Maciej Postek" />}
    <div>
      <span class="metric-label">{eyebrow}</span>
      <h2>{title}</h2>
    </div>
  </div>
  <a class="button button--primary" href={href}>
    {action}
    <ArrowRight size={15} />
  </a>
</section>
