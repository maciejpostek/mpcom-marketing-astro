---
import { resolveProps, style } from "meno-astro";
import ActionButton from "./ActionButton.astro";

const __props = resolveProps(Astro, {
  eyebrow: { type: "string", default: "Start with context" },
  title: { type: "string", default: "Define what the system actually needs." },
  action: { type: "string", default: "Start a conversation" },
  href: { type: "link", default: { href: "/contact" } },
  portrait: { type: "boolean", default: false }
});
const { eyebrow, title, action, href, portrait, class: className } = __props;

const __meno = { acceptsStyles: true };
---

<section
  class={style(
    {
      base: {
        marginTop: "64px",
        padding: "34px",
        display: "flex",
        justifyContent: "space-between",
        alignItems: "center",
        gap: "32px",
        backgroundColor: "var(--gray-950)",
        color: "#ffffff"
      },
      tablet: { alignItems: "flex-start", flexDirection: "column" },
      mobile: {}
    },
    __props,
    { root: true, label: "Callout" }
  )}
>
  <div class={style({ base: { display: "flex", alignItems: "center", gap: "18px" }, tablet: {}, mobile: {} }, __props)}>
    {portrait && <img src="/images/maciej-portrait.jpg" alt="Maciej Postek" class={style({ base: { width: "52px", height: "52px", objectFit: "cover", borderRadius: "50%" }, tablet: {}, mobile: {} }, __props)} />}
    <div class={style({ base: {}, tablet: {}, mobile: {} }, __props)}>
      <span class={style({ base: { display: "block", marginBottom: "9px", color: "var(--blue-300)", fontSize: "11px", fontWeight: "600", textTransform: "uppercase" }, tablet: {}, mobile: {} }, __props)}>{eyebrow}</span>
      <h2 class={style({ base: { maxWidth: "760px", margin: "0", fontSize: "24px", lineHeight: "1.28", fontWeight: "500" }, tablet: {}, mobile: {} }, __props)}>{title}</h2>
    </div>
  </div>
  <ActionButton text={action} link={href} variant="primary" />
</section>
