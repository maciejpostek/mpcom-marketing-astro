---
import { resolveProps, style } from "meno-astro";

const __props = resolveProps(Astro, {
  index: { type: "string", default: "01" },
  eyebrow: { type: "string", default: "Section" },
  title: { type: "string", default: "Section title" },
  description: { type: "string", default: "Section description." }
});
const { index, eyebrow, title, description, class: className } = __props;

const __meno = { acceptsStyles: true };
---

<div
  class={style(
    {
      base: {
        display: "grid",
        gridTemplateColumns: "minmax(160px, 0.35fr) minmax(0, 1fr)",
        gap: "40px",
        alignItems: "start",
        marginBottom: "40px"
      },
      tablet: { gridTemplateColumns: "1fr", gap: "18px" },
      mobile: {}
    },
    __props,
    { root: true, label: "Section intro" }
  )}
>
  <div
    class={style(
      {
        base: {
          display: "flex",
          alignItems: "center",
          gap: "10px",
          paddingTop: "7px"
        },
        tablet: {},
        mobile: {}
      },
      __props
    )}
  >
    <span
      class={style(
        {
          base: {
            width: "22px",
            height: "2px",
            backgroundColor: "var(--blue-600)"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    />
    <span
      class={style(
        {
          base: {
            color: "var(--gray-500)",
            fontSize: "11px",
            fontWeight: "600"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {index}
    </span>
    <span
      class={style(
        {
          base: {
            color: "var(--gray-600)",
            fontSize: "12px",
            fontWeight: "500"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {eyebrow}
    </span>
  </div>
  <div
    class={style(
      {
        base: {
          display: "grid",
          gridTemplateColumns: "minmax(0, 1.35fr) minmax(240px, 0.65fr)",
          gap: "48px",
          alignItems: "start"
        },
        tablet: { gridTemplateColumns: "1fr", gap: "16px" },
        mobile: {}
      },
      __props
    )}
  >
    <h2
      class={style(
        {
          base: {
            margin: "0",
            maxWidth: "700px",
            color: "var(--gray-950)",
            fontSize: "var(--section-title-size)",
            lineHeight: "1.15",
            fontWeight: "500"
          },
          tablet: {},
          mobile: { fontSize: "26px" }
        },
        __props
      )}
    >
      {title}
    </h2>
    <p
      class={style(
        {
          base: {
            margin: "3px 0 0",
            maxWidth: "420px",
            color: "var(--gray-500)",
            fontSize: "14px",
            lineHeight: "1.6"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {description}
    </p>
  </div>
</div>
