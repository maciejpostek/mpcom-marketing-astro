---
import { resolveProps } from "meno-astro";

const __props = resolveProps(Astro, {
  variant: {
    type: "select",
    default: "avatar",
    options: ["avatar", "hero", "callout", "contact"]
  },
  title: { type: "string", default: "Maciej Postek" },
  image: {
    type: "file",
    accept: "image/*",
    default: "/images/maciej-portrait.jpg"
  }
});
const { variant, title, image } = __props;

const __meno = { acceptsStyles: true };
---

<span class={`portrait portrait--${variant}`} title={title}>
  <img src={image} alt={title} loading={variant === "hero" ? "eager" : "lazy"} />
</span>
