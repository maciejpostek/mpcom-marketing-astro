---
import { resolveProps, style } from "meno-astro";

const __props = resolveProps(Astro, {
  image: { type: "image", default: "/images/dashboard-shell.png" },
  imageAlt: { type: "string", default: "Project preview" },
  eyebrow: { type: "string", default: "Case study" },
  year: { type: "string", default: "2026" },
  title: { type: "string", default: "Project title" },
  description: { type: "string", default: "Project description." },
  scope: { type: "string", default: "Strategy · Design · Development" }
});
const { image, imageAlt, eyebrow, year, title, description, scope, class: className } = __props;

const __meno = { acceptsStyles: true };
---

<article
  class={style(
    {
      base: {
        overflow: "hidden",
        border: "1px solid var(--gray-200)",
        backgroundColor: "var(--white)"
      },
      tablet: {},
      mobile: {}
    },
    __props,
    { root: true, label: "Proof card" }
  )}
>
  <div
    class={style(
      {
        base: {
          padding: "18px",
          backgroundColor: "var(--gray-100)",
          borderBottom: "1px solid var(--gray-200)"
        },
        tablet: {},
        mobile: {}
      },
      __props
    )}
  >
    <img
      class={style(
        {
          base: {
            width: "100%",
            aspectRatio: "16 / 9",
            display: "block",
            objectFit: "cover",
            border: "1px solid var(--gray-200)"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
      src={image || undefined}
      alt={imageAlt || undefined}
    />
  </div>
  <div
    class={style(
      {
        base: { padding: "24px" },
        tablet: {},
        mobile: {}
      },
      __props
    )}
  >
    <div
      class={style(
        {
          base: {
            display: "flex",
            justifyContent: "space-between",
            gap: "16px",
            marginBottom: "20px",
            color: "var(--gray-500)",
            fontSize: "11px",
            fontWeight: "600",
            textTransform: "uppercase"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      <span>{eyebrow}</span>
      <span>{year}</span>
    </div>
    <h3
      class={style(
        {
          base: {
            margin: "0 0 12px",
            color: "var(--gray-950)",
            fontSize: "22px",
            lineHeight: "1.2",
            fontWeight: "500"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {title}
    </h3>
    <p
      class={style(
        {
          base: {
            margin: "0 0 22px",
            color: "var(--gray-500)",
            fontSize: "14px",
            lineHeight: "1.55"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {description}
    </p>
    <span
      class={style(
        {
          base: {
            color: "var(--gray-700)",
            fontSize: "12px",
            lineHeight: "1.45"
          },
          tablet: {},
          mobile: {}
        },
        __props
      )}
    >
      {scope}
    </span>
  </div>
</article>
