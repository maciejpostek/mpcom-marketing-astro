---
import { resolveProps } from "meno-astro";

const __props = resolveProps(Astro, {
  eyebrow: { type: "string", default: "Section" },
  title: { type: "string", default: "Page title" },
  description: { type: "string", default: "Supporting description." }
});
const { eyebrow, title, description } = __props;

const __meno = { acceptsStyles: true };
---

<header class="page-header">
  <div>
    <span class="eyebrow">
      <span class="eyebrow__line"></span>
      {eyebrow}
    </span>
    <h1>{title}</h1>
  </div>
  <div class="page-header__support">
    <p>{description}</p>
    <slot />
  </div>
</header>
